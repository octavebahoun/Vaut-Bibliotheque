# ─────────────────────────────────────────────────────────────
#  Vault — variables d'environnement
#  Copie ce fichier en `.env.local` et remplis les valeurs.
#  Sur Vercel : Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Neon Postgres — chaîne de connexion (avec ?sslmode=require)
# https://console.neon.tech → ton projet → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/vault?sslmode=require"

# Clé de chiffrement (AES-256-GCM) — chiffre les secrets .env ET les
# API secrets Cloudinary de chaque utilisateur, stockés en base.
# DOIT faire exactement 32 octets en base64 :  openssl rand -base64 32
SECRETS_ENCRYPTION_KEY="change-me-openssl-rand-base64-32"

# ─────────────────────────────────────────────────────────────
#  Cloudinary n'est PAS configuré ici : chaque utilisateur branche
#  son propre compte depuis l'app (page Réglages). Rien à mettre.
# ─────────────────────────────────────────────────────────────

# ── E-mail (invitations) — OPTIONNEL ─────────────────────────
# Sans ces variables, les invitations fonctionnent quand même
# (lien copiable) ; seul l'envoi automatique par e-mail est désactivé.
# Resend : https://resend.com — crée une clé API.
RESEND_API_KEY=""
# Adresse expéditrice. En test : "Vault <onboarding@resend.dev>"
# (n'envoie qu'à ta propre adresse). En prod : un domaine vérifié.
EMAIL_FROM="Vault <onboarding@resend.dev>"

# URL publique de l'app (pour les liens dans les e-mails).
# Optionnel : déduit des en-têtes de la requête si absent.
APP_URL="https://vaut-bibliotheque.vercel.app"
